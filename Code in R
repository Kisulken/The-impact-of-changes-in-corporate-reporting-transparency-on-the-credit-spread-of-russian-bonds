library(readxl)
library(plm)
library(dplyr)

# Загрузка данных (один раз, вне цикла)
data_new     <- read_excel("result_dates6.xlsx")
data_company <- read_excel("result_dates7.xlsx")

# Список для хранения результатов
results <- list()

for (liq_level in seq(10000, 1000000, by = 10000)) {
  
  cat("\n--- liq_level:", liq_level, "---\n")
  
  # Фильтрация данных
  data_pre_period_test  <- data_new[data_new$t_number < -5 & data_new$avg_liq >= liq_level, ]
  data_post_period_test <- data_new[data_new$t_number >= -5 & data_new$avg_liq >= liq_level, ]
  data_company_test     <- data_company[data_company$liq >= liq_level, ]
  
  # Пропускаем итерацию если данных недостаточно
  if (nrow(data_pre_period_test) < 10 | nrow(data_post_period_test) < 10) {
    cat("Недостаточно данных, пропускаем\n")
    next
  }
  
  # Панельный формат и FE модель
  pdata_test <- pdata.frame(data_pre_period_test, index = c("year_and_name", "t_number"))
  
  fe_test <- tryCatch(
    plm(scs ~ r_f + slope + RVI + imoex + duration,
        data = pdata_test, model = "within"),
    error = function(e) {
      cat("Ошибка FE модели:", e$message, "\n")
      return(NULL)
    }
  )
  
  if (is.null(fe_test)) next
  
  # Достаем коэффициенты
  b1 <- fe_test$coefficients[1]
  b2 <- fe_test$coefficients[2]
  b3 <- fe_test$coefficients[3]
  b4 <- fe_test$coefficients[4]
  b5 <- fe_test$coefficients[5]
  
  # Считаем y_hat и ошибки
  y_hat <- b1 * data_post_period_test$r_f +
    b2 * data_post_period_test$slope +
    b3 * data_post_period_test$RVI +
    b4 * data_post_period_test$imoex +
    b5 * data_post_period_test$duration
  
  data_post_period_test$post_errors <- data_post_period_test$scs - y_hat
  
  # Суммарные ошибки по облигациям
  sum_errors <- data_post_period_test %>%
    group_by(year_and_name) %>%
    summarise(sum_errors = sum(post_errors), .groups = "drop")
  
  # Join вместо прямого присвоения (исправление прошлой проблемы)
  data_company_test <- data_company_test %>%
    left_join(sum_errors, by = "year_and_name")
  
  # Пропускаем если нет пересечений
  if (all(is.na(data_company_test$sum_errors))) {
    cat("Нет пересечений между data_company_test и sum_errors, пропускаем\n")
    next
  }
  
  # Панельный формат и RE модель
  pdata2_test <- pdata.frame(data_company_test, index = c("name", "year"))
  
  re_final_test <- tryCatch(
    plm(sum_errors ~ transp_index, data = pdata2_test, model = "random"),
    error = function(e) {
      cat("Ошибка RE модели:", e$message, "\n")
      return(NULL)
    }
  )

  if (is.null(re_final_test)) next
  # Сохраняем результаты
  results[[as.character(liq_level)]] <- list(
    liq_level     = liq_level,
    n_pre         = nrow(data_pre_period_test),
    n_post        = nrow(data_post_period_test),
    n_company     = nrow(data_company_test),
    fe_coefs      = coef(fe_test),
    re_coef       = coef(re_final_test)["transp_index"],
    re_pvalue     = summary(re_final_test)$coefficients["transp_index", 4]
  )
  
  cat("RE коэффициент transp_index:", round(coef(re_final_test)["transp_index"], 4),
      "| p-value:", round(summary(re_final_test)$coefficients["transp_index", 4], 4), "\n")
}

# Итоговая таблица результатов
results_df <- bind_rows(lapply(results, function(x) {
  data.frame(
    liq_level  = x$liq_level,
    n_pre      = x$n_pre,
    n_post     = x$n_post,
    n_company  = x$n_company,
    re_coef    = x$re_coef,
    re_pvalue  = x$re_pvalue
  )
}))

print(results_df)


